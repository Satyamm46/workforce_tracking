# ==========================================================
#  Java / Maven (backend)
# ==========================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Compiled output
*.class

# Log files
logs/
*.log

# ==========================================================
#  Spring Boot — local secrets & overrides
# ==========================================================
# Never commit machine-specific or secret-bearing overrides.
# application.properties and application-dev.properties hold real
# credentials (mail, VAPID, DB) and must stay out of git. Keep the
# env-var-only application-prod.properties as the safe reference template.
application.properties
application-dev.properties
application-local.properties
src/main/resources/application.properties
src/main/resources/application-dev.properties
*.env
.env

# ==========================================================
#  IDE — IntelliJ IDEA
# ==========================================================
.idea/
*.iml
*.iws
*.ipr

# ==========================================================
#  IDE — Eclipse / VS Code
# ==========================================================
.settings/
.project
.classpath
.vscode/
bin/

# ==========================================================
#  Node / React (frontend — added preemptively)
# ==========================================================
node_modules/
dist/
dist-ssr/
*.local
frontend/node_modules/
frontend/dist/

# ==========================================================
#  OS junk
# ==========================================================
.DS_Store
Thumbs.db